{
    "phases": {
        "setup": {
            "nixPkgs": [
                "php83",
                "php83Extensions.mysqlnd",
                "nginx",
                "php83Packages.composer",
                "nodejs_22"
            ]
        },
        "install": {
            "cmds": [
                "mkdir -p /var/log/nginx && mkdir -p /var/cache/nginx",
                "composer install --ignore-platform-reqs"
            ]
        }
    },
    "start": {
        "cmd": "php-fpm -D && nginx -g 'daemon off;' -c /app/nginx.conf"
    }
}
